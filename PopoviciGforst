<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>POPOVICI GBR | Aufforstung, Baumfällung & Forstdienstleistungen in Deutschland</title>
  <meta
    name="description"
    content="POPOVICI GBR – professionelle Forst- und Landschaftspflege in Deutschland. Baumfällung, Aufforstung, Nachpflanzung, Baumpflege, Fällung von Gefahrenbäumen, Hecken- und Grünpflege, Freischneiden, Jungbestandspflege, Durchforstung und Kulturpflege."
  />
  <meta
    name="keywords"
    content="POPOVICI GBR, Baumfällung, Aufforstung, Nachpflanzung, Baumpflege, Gefahrenbaumfällung, Hecken- und Grünpflege, Freischneiden, Jungbestandspflege, Durchforstung, Kulturpflege, Obernheim, Deutschland"
  />
  <meta name="author" content="POPOVICI GBR" />
  <meta name="theme-color" content="#143322" />
  <meta property="og:title" content="POPOVICI GBR | Forst- & Landschaftspflege" />
  <meta
    property="og:description"
    content="Professionelle Forst- und Pflegearbeiten – zuverlässig, sauber und termingerecht."
  />
  <meta property="og:type" content="website" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700;800&family=Inter:wght@400;500;600;700;800&display=swap"
    rel="stylesheet"
  />

  <style>
    :root {
      --bg: #f6f4ee;
      --surface: #ffffff;
      --surface-soft: rgba(255,255,255,0.82);
      --text: #17211b;
      --muted: #627066;
      --primary: #143322;
      --primary-2: #214a34;
      --primary-3: #2d6448;
      --accent: #9b7645;
      --accent-2: #c19b6a;
      --line: rgba(20, 51, 34, 0.10);
      --shadow: 0 12px 35px rgba(16, 28, 21, 0.08);
      --shadow-lg: 0 24px 60px rgba(16, 28, 21, 0.16);
      --radius: 26px;
      --radius-sm: 18px;
      --transition: all 0.35s ease;
      --max-width: 1240px;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html {
      scroll-behavior: smooth;
    }

    body {
      font-family: "Inter", sans-serif;
      color: var(--text);
      background:
        radial-gradient(circle at top left, rgba(155,118,69,0.05), transparent 20%),
        radial-gradient(circle at right center, rgba(33,74,52,0.04), transparent 24%),
        var(--bg);
      line-height: 1.65;
      overflow-x: hidden;
    }

    body.menu-open {
      overflow: hidden;
    }

    a {
      text-decoration: none;
      color: inherit;
    }

    img {
      display: block;
      max-width: 100%;
    }

    button,
    input,
    textarea,
    select {
      font: inherit;
    }

    .container {
      width: min(var(--max-width), calc(100% - 40px));
      margin: 0 auto;
    }

    .section {
      padding: 110px 0;
      position: relative;
    }

    .section-heading {
      max-width: 860px;
      margin: 0 auto 54px;
      text-align: center;
    }

    .section-tag {
      display: inline-flex;
      align-items: center;
      padding: 9px 16px;
      border-radius: 999px;
      background: rgba(20,51,34,0.06);
      border: 1px solid rgba(20,51,34,0.08);
      color: var(--primary);
      font-size: 0.82rem;
      font-weight: 800;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      margin-bottom: 18px;
    }

    .section h2 {
      font-family: "Playfair Display", serif;
      font-size: clamp(2.1rem, 4vw, 3.5rem);
      line-height: 1.12;
      color: var(--primary);
      margin-bottom: 16px;
    }

    .section-heading p,
    .section p {
      color: var(--muted);
      font-size: 1.02rem;
    }

    .topbar {
      background: #10241a;
      color: rgba(255,255,255,0.78);
      border-bottom: 1px solid rgba(255,255,255,0.06);
      font-size: 0.92rem;
    }

    .topbar-inner {
      min-height: 46px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
      flex-wrap: wrap;
    }

    .topbar-right {
      display: flex;
      gap: 18px;
      flex-wrap: wrap;
    }

    .topbar a:hover {
      color: #fff;
    }

    .header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(246,244,238,0.84);
      backdrop-filter: blur(18px);
      border-bottom: 1px solid rgba(20,51,34,0.08);
    }

    .nav-wrap {
      min-height: 88px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 20px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 14px;
      min-width: 0;
    }

    .logo-badge {
      width: 64px;
      height: 64px;
      border-radius: 20px;
      background: linear-gradient(145deg, #143121, #2c5e42);
      display: grid;
      place-items: center;
      box-shadow: var(--shadow);
      border: 1px solid rgba(255,255,255,0.08);
      flex-shrink: 0;
    }

    .logo-badge svg {
      width: 44px;
      height: 44px;
    }

    .logo-text {
      display: flex;
      flex-direction: column;
      line-height: 1.08;
      min-width: 0;
    }

    .logo-text strong {
      font-size: 1rem;
      font-weight: 800;
      letter-spacing: 0.10em;
      color: var(--primary);
    }

    .logo-text span {
      color: var(--muted);
      font-size: 0.76rem;
      text-transform: uppercase;
      letter-spacing: 0.10em;
    }

    .nav {
      display: flex;
      align-items: center;
      gap: 28px;
    }

    .nav a {
      position: relative;
      font-weight: 600;
      font-size: 0.97rem;
      color: var(--text);
    }

    .nav a::after {
      content: "";
      position: absolute;
      bottom: -7px;
      left: 0;
      width: 0;
      height: 2px;
      border-radius: 999px;
      background: linear-gradient(90deg, var(--accent), var(--accent-2));
      transition: var(--transition);
    }

    .nav a:hover {
      color: var(--primary);
    }

    .nav a:hover::after {
      width: 100%;
    }

    .nav-actions {
      display: flex;
      align-items: center;
      gap: 14px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 14px 24px;
      border-radius: 999px;
      border: 1px solid transparent;
      font-weight: 700;
      cursor: pointer;
      transition: var(--transition);
      white-space: nowrap;
    }

    .btn-primary {
      background: linear-gradient(135deg, var(--primary), var(--primary-3));
      color: #fff;
      box-shadow: 0 12px 30px rgba(20,51,34,0.24);
    }

    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 38px rgba(20,51,34,0.28);
    }

    .btn-secondary {
      background: rgba(255,255,255,0.76);
      color: var(--primary);
      border-color: rgba(20,51,34,0.10);
      backdrop-filter: blur(10px);
    }

    .btn-secondary:hover {
      background: #fff;
      transform: translateY(-2px);
    }

    .btn-light {
      background: rgba(255,255,255,0.10);
      border-color: rgba(255,255,255,0.18);
      color: #fff;
      backdrop-filter: blur(10px);
    }

    .btn-light:hover {
      background: rgba(255,255,255,0.18);
      transform: translateY(-2px);
    }

    .burger {
      display: none;
      width: 48px;
      height: 48px;
      border-radius: 14px;
      border: 1px solid var(--line);
      background: #fff;
      cursor: pointer;
      padding: 0 12px;
      flex-direction: column;
      justify-content: center;
      gap: 5px;
    }

    .burger span {
      display: block;
      width: 100%;
      height: 2px;
      border-radius: 999px;
      background: var(--primary);
      transition: var(--transition);
    }

    .burger.active span:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    .burger.active span:nth-child(2) {
      opacity: 0;
    }

    .burger.active span:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }

    .mobile-menu {
      display: none;
      background: rgba(246,244,238,0.98);
      border-top: 1px solid rgba(20,51,34,0.08);
      border-bottom: 1px solid rgba(20,51,34,0.08);
      backdrop-filter: blur(18px);
    }

    .mobile-menu.active {
      display: block;
    }

    .mobile-menu-inner {
      display: flex;
      flex-direction: column;
      gap: 14px;
      padding: 18px 0 24px;
    }

    .mobile-menu a {
      font-weight: 700;
      color: var(--primary);
      padding: 10px 0;
    }

    .hero {
      min-height: calc(100vh - 134px);
      position: relative;
      display: flex;
      align-items: center;
      overflow: hidden;
      background:
        linear-gradient(rgba(14, 27, 20, 0.60), rgba(14, 27, 20, 0.62)),
        url("https://images.unsplash.com/photo-1448375240586-882707db888b?auto=format&fit=crop&w=1800&q=80") center/cover no-repeat;
    }

    .hero::before {
      content: "";
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at top right, rgba(193,155,106,0.18), transparent 25%),
        radial-gradient(circle at bottom left, rgba(52,112,78,0.18), transparent 25%);
    }

    .hero-inner {
      position: relative;
      z-index: 2;
      display: grid;
      grid-template-columns: 1.2fr 0.8fr;
      gap: 42px;
      align-items: center;
      padding: 90px 0;
    }

    .eyebrow {
      display: inline-flex;
      align-items: center;
      padding: 10px 16px;
      border-radius: 999px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.16);
      color: #efe7da;
      font-size: 0.82rem;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.10em;
      margin-bottom: 18px;
    }

    .hero h1 {
      color: #fff;
      font-family: "Playfair Display", serif;
      font-size: clamp(2.8rem, 5.8vw, 5.3rem);
      line-height: 1.02;
      margin-bottom: 20px;
      max-width: 860px;
    }

    .hero p {
      color: rgba(255,255,255,0.88);
      font-size: 1.08rem;
      max-width: 760px;
      margin-bottom: 30px;
    }

    .hero-actions {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      margin-bottom: 34px;
    }

    .hero-metrics {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .metric-card {
      padding: 20px;
      border-radius: 20px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.14);
      backdrop-filter: blur(10px);
      color: #fff;
    }

    .metric-card strong {
      display: block;
      margin-bottom: 4px;
      font-size: 1.08rem;
    }

    .hero-side-card {
      border-radius: 30px;
      padding: 34px;
      background: rgba(255,255,255,0.12);
      border: 1px solid rgba(255,255,255,0.14);
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow-lg);
      color: #fff;
    }

    .hero-side-card h3 {
      font-family: "Playfair Display", serif;
      font-size: 1.9rem;
      margin-bottom: 16px;
    }

    .hero-side-card ul {
      list-style: none;
      margin-bottom: 24px;
    }

    .hero-side-card li {
      padding: 12px 0;
      border-bottom: 1px solid rgba(255,255,255,0.12);
      color: rgba(255,255,255,0.9);
    }

    .trust-strip {
      margin-top: -35px;
      position: relative;
      z-index: 4;
    }

    .trust-grid {
      background: rgba(255,255,255,0.82);
      border: 1px solid rgba(20,51,34,0.08);
      backdrop-filter: blur(16px);
      box-shadow: var(--shadow);
      border-radius: 26px;
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
      padding: 26px;
    }

    .trust-item {
      display: flex;
      gap: 14px;
      align-items: flex-start;
    }

    .trust-icon {
      width: 50px;
      height: 50px;
      border-radius: 16px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(20,51,34,0.08), rgba(193,155,106,0.18));
      color: var(--primary);
      font-size: 1.3rem;
      flex-shrink: 0;
    }

    .trust-item strong {
      display: block;
      color: var(--primary);
      margin-bottom: 2px;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 54px;
      align-items: center;
    }

    .about-image {
      min-height: 580px;
      border-radius: 30px;
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      background:
        linear-gradient(rgba(19,36,26,0.20), rgba(19,36,26,0.22)),
        url("https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1200&q=80") center/cover no-repeat;
    }

    .about-content h2 {
      text-align: left;
    }

    .about-content p + p {
      margin-top: 14px;
    }

    .premium-boxes {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 18px;
      margin-top: 30px;
    }

    .premium-box {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 22px;
      padding: 24px;
      box-shadow: var(--shadow);
    }

    .premium-box strong {
      display: block;
      color: var(--primary);
      margin-bottom: 6px;
      font-size: 1.03rem;
    }

    .services {
      background: linear-gradient(180deg, #f7f5ef 0%, #fbfaf7 100%);
    }

    .services-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }

    .service-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(20,51,34,0.08);
      border-radius: 26px;
      padding: 28px;
      box-shadow: var(--shadow);
      transition: var(--transition);
      position: relative;
      overflow: hidden;
    }

    .service-card::before {
      content: "";
      position: absolute;
      inset: 0 auto auto 0;
      width: 100%;
      height: 5px;
      background: linear-gradient(90deg, var(--primary), var(--accent-2));
    }

    .service-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg);
    }

    .service-icon {
      width: 66px;
      height: 66px;
      border-radius: 18px;
      display: grid;
      place-items: center;
      background: linear-gradient(135deg, rgba(20,51,34,0.09), rgba(193,155,106,0.18));
      color: var(--primary);
      font-size: 1.8rem;
      margin-bottom: 18px;
    }

    .service-card h3 {
      color: var(--primary);
      margin-bottom: 12px;
      font-size: 1.15rem;
    }

    .why-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .why-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 30px;
      box-shadow: var(--shadow);
      transition: var(--transition);
    }

    .why-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }

    .why-number {
      display: inline-flex;
      width: 50px;
      height: 50px;
      align-items: center;
      justify-content: center;
      border-radius: 16px;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      font-weight: 800;
      margin-bottom: 16px;
    }

    .why-card h3 {
      color: var(--primary);
      margin-bottom: 10px;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(12, 1fr);
      gap: 20px;
    }

    .gallery-card {
      position: relative;
      overflow: hidden;
      border-radius: 28px;
      min-height: 280px;
      box-shadow: var(--shadow);
      transition: var(--transition);
    }

    .gallery-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg);
    }

    .gallery-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(10,20,14,0.82), rgba(10,20,14,0.10));
      z-index: 1;
    }

    .gallery-card.large {
      grid-column: span 5;
      min-height: 580px;
    }

    .gallery-card.medium {
      grid-column: span 7;
      min-height: 280px;
    }

    .gallery-card.small {
      grid-column: span 4;
      min-height: 260px;
    }

    .gallery-card.wide {
      grid-column: span 8;
      min-height: 260px;
    }

    .gallery-card:nth-child(1) {
      background: url("https://images.unsplash.com/photo-1511497584788-876760111969?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
    }

    .gallery-card:nth-child(2) {
      background: url("https://images.unsplash.com/photo-1466692476868-aef1dfb1e735?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
    }

    .gallery-card:nth-child(3) {
      background: url("https://images.unsplash.com/photo-1501004318641-b39e6451bec6?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
    }

    .gallery-card:nth-child(4) {
      background: url("https://images.unsplash.com/photo-1500382017468-9049fed747ef?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
    }

    .gallery-card:nth-child(5) {
      background: url("https://images.unsplash.com/photo-1441974231531-c6227db76b6e?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat;
    }

    .gallery-text {
      position: absolute;
      left: 24px;
      right: 24px;
      bottom: 24px;
      z-index: 2;
      color: #fff;
    }

    .gallery-text h3 {
      margin-bottom: 5px;
      font-size: 1.2rem;
    }

    .process {
      background:
        radial-gradient(circle at top left, rgba(155,118,69,0.06), transparent 20%),
        linear-gradient(180deg, #faf8f3, #f4f1e8);
    }

    .process-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 20px;
    }

    .process-step {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 28px 22px;
      box-shadow: var(--shadow);
    }

    .process-step span {
      display: inline-flex;
      width: 54px;
      height: 54px;
      align-items: center;
      justify-content: center;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--primary), var(--accent));
      color: #fff;
      font-weight: 800;
      margin-bottom: 18px;
    }

    .process-step h3 {
      color: var(--primary);
      margin-bottom: 10px;
      font-size: 1.06rem;
    }

    .reviews-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .review-card {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 24px;
      padding: 30px;
      box-shadow: var(--shadow);
      transition: var(--transition);
    }

    .review-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow-lg);
    }

    .stars {
      color: #c79f67;
      letter-spacing: 0.18em;
      margin-bottom: 16px;
      font-size: 1.02rem;
    }

    .review-card p {
      margin-bottom: 16px;
    }

    .review-card h4 {
      color: var(--primary);
      font-size: 0.98rem;
    }

    .faq-grid {
      display: grid;
      gap: 16px;
      max-width: 980px;
      margin: 0 auto;
    }

    .faq-item {
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(20,51,34,0.08);
      border-radius: 22px;
      box-shadow: var(--shadow);
      overflow: hidden;
    }

    .faq-question {
      width: 100%;
      background: transparent;
      border: none;
      cursor: pointer;
      text-align: left;
      padding: 24px 26px;
      color: var(--primary);
      font-weight: 800;
      font-size: 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 18px;
    }

    .faq-question span:last-child {
      font-size: 1.4rem;
      line-height: 1;
      transition: var(--transition);
    }

    .faq-item.active .faq-question span:last-child {
      transform: rotate(45deg);
    }

    .faq-answer {
      max-height: 0;
      overflow: hidden;
      transition: max-height 0.35s ease;
      padding: 0 26px;
    }

    .faq-answer p {
      padding-bottom: 22px;
    }

    .contact-grid {
      display: grid;
      grid-template-columns: 0.95fr 1.05fr;
      gap: 32px;
      align-items: start;
    }

    .info-panel,
    .form-panel,
    .legal-card {
      background: rgba(255,255,255,0.88);
      border: 1px solid rgba(20,51,34,0.08);
      box-shadow: var(--shadow);
    }

    .info-panel {
      border-radius: 28px;
      padding: 34px;
    }

    .info-panel h2 {
      text-align: left;
    }

    .contact-boxes {
      display: grid;
      gap: 16px;
      margin: 28px 0;
    }

    .contact-box {
      background: #fff;
      border: 1px solid var(--line);
      border-radius: 20px;
      padding: 22px;
    }

    .contact-box h3 {
      color: var(--primary);
      margin-bottom: 10px;
    }

